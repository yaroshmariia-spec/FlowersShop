<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowersShop.ViewModels"
             x:DataType="vm:LoginViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FlowersShop.Views.LoginView">
    
    <Grid Background="{DynamicResource SystemRegionBrush}">
        <Border Classes="Card" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="15">
                <TextBlock Text="FlowersShop" FontSize="26" FontWeight="Black" 
                           Foreground="{DynamicResource BrandPinkBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Електронна пошта" Foreground="Gray" FontSize="12"/>
                <TextBox Text="{Binding Email}" Watermark="email@example.com" CornerRadius="5"/>

                <TextBlock Text="Пароль" Foreground="Gray" FontSize="12"/>
                <TextBox Text="{Binding Password}" PasswordChar="*" Watermark="••••••••" CornerRadius="5"/>

                <Button Classes="Primary" Content="Увійти" Command="{Binding LoginCommand}" 
                        HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
                <Button Content="Немає акаунту? Зареєструватися" 
                        Background="Transparent" Foreground="Gray" FontSize="11" 
                        HorizontalAlignment="Center" Margin="0,5,0,0"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowRegistrationCommand}"/>

                <Button Content="Забули пароль?" Background="Transparent" Foreground="Gray" 
                        FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
