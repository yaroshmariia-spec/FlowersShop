<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowersShop.ViewModels"
             x:DataType="vm:CatalogViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FlowersShop.Views.CatalogView">

    <Grid ColumnDefinitions="*, Auto" Margin="20">

        <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,20,0">
            
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                <TextBox Grid.Column="0" Text="{Binding SearchText}" 
                         Watermark="🔍 Пошук за назвою..." 
                         Margin="0,0,20,0" Padding="10" CornerRadius="5" FontSize="16" VerticalAlignment="Center"
                         Background="White" BorderBrush="#FFB6C1" BorderThickness="1"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                    <Button Content="+ Додати товар" Command="{Binding AddNewFlowerCommand}" 
                            Background="#FF69B4" Foreground="White" FontWeight="Bold" Padding="15,8" CornerRadius="5"/>
                    <Button Content="Видалити обране" Command="{Binding DeleteSelectedCommand}" 
                            Background="#FFB6C1" Foreground="White" Padding="15,8" CornerRadius="5"/>
                </StackPanel>
            </Grid>

            <ListBox Grid.Row="1" ItemsSource="{Binding Flowers}" SelectedItem="{Binding SelectedFlower}" 
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="20" Margin="5" BoxShadow="0 2 10 0 #10000000">
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="18" Foreground="#333333"/>
                                    <TextBlock Text="{Binding Category}" FontSize="12" Foreground="Gray" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0} грн.'}" 
                                               Foreground="#FF69B4" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StockQuantity, StringFormat='Залишок: {0} шт.'}" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Column="1" Width="350" Background="White" CornerRadius="10" Padding="25" 
                IsVisible="{Binding IsFormVisible}" BoxShadow="-5 0 15 0 #10000000">
            <StackPanel Spacing="15">
                <TextBlock Text="Картка товару" FontWeight="Bold" FontSize="20" Foreground="#FF69B4" Margin="0,0,0,10"/>

                <TextBlock Text="Назва:" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBox Text="{Binding EditingFlower.Name}" Watermark="Введіть назву..." Padding="10" CornerRadius="5"/>

                <TextBlock Text="Категорія:" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBox Text="{Binding EditingFlower.Category}" Watermark="Наприклад: Вазони" Padding="10" CornerRadius="5"/>

                <TextBlock Text="Ціна (грн):" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBox Text="{Binding EditingFlower.Price}" Watermark="0.00" Padding="10" CornerRadius="5"/>

                <TextBlock Text="Залишок на складі:" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBox Text="{Binding EditingFlower.StockQuantity}" Watermark="Штуки..." Padding="10" CornerRadius="5"/>

                <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                    <Button Grid.Column="0" Content="Зберегти" Command="{Binding SaveFlowerCommand}" 
                            Background="#32CD32" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" CornerRadius="5" Padding="10"/>
                    
                    <Button Grid.Column="1" Content="Скасувати" Command="{Binding CancelEditCommand}" 
                            Background="#A9A9A9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" CornerRadius="5" Padding="10"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
