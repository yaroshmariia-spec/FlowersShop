<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowersShop.ViewModels"
             x:DataType="vm:CatalogViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FlowersShop.Views.CatalogView">

    <Grid ColumnDefinitions="*, Auto" Margin="20">

        <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,20,0">
            
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                <TextBox Grid.Column="0" Text="{Binding SearchText}" 
                         Watermark="🔍 Пошук за назвою..." 
                         Margin="0,0,20,0" Padding="10" CornerRadius="5" FontSize="16" VerticalAlignment="Center"
                         BorderBrush="{DynamicResource BrandLightPinkBrush}" BorderThickness="1"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                    <Button Content="+ Додати товар" Command="{Binding AddNewFlowerCommand}" 
                            Classes="Primary"/>
                    <Button Content="Видалити обране" Command="{Binding DeleteSelectedCommand}" 
                            Classes="Secondary"/>
                </StackPanel>
            </Grid>

            <ListBox Grid.Row="1" ItemsSource="{Binding Flowers}" SelectedItem="{Binding SelectedFlower}" 
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="Card" Margin="5" Background="{DynamicResource BrandPinkBrush}">
                            <Grid ColumnDefinitions="*, Auto">
    
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="18" 
                                               Foreground="{DynamicResource SystemBaseHighColor}"/>
        
                                    <TextBlock Text="{Binding Category}" FontSize="12" 
                                               Foreground="{DynamicResource SystemBaseMediumColor}" Margin="0,2,0,0"/>
        
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0} грн.'}" 
                                               Foreground="{DynamicResource BrandPinkBrush}" FontWeight="Bold" FontSize="16" Margin="0,10,0,0"/>
                                </StackPanel>
    
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StockQuantity, StringFormat='Залишок: {0} шт.'}" 
                                               FontSize="12" Foreground="{DynamicResource SystemBaseMediumColor}"/>
                                </StackPanel>
    
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Classes="Card" Grid.Column="1" Width="350" IsVisible="{Binding IsFormVisible}" BoxShadow="-5 0 15 0 #10000000">
            <StackPanel Spacing="15">
                <TextBlock Text="Картка товару" FontWeight="Bold" FontSize="20" Foreground="#FF69B4" Margin="0,0,0,10"/>

                <TextBlock Text="Назва:" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBox Text="{Binding EditingFlower.Name}" Watermark="Введіть назву..." Padding="10" CornerRadius="5"/>

                <TextBlock Text="Категорія:" FontWeight="SemiBold" Foreground="Gray"/>
                <TextBox Text="{Binding EditingFlower.Category}" Watermark="Наприклад: Вазони" Padding="10" CornerRadius="5"/>

                <TextBlock Text="Ціна (грн):" FontWeight="SemiBold" Foreground="Gray"/>
                <NumericUpDown Value="{Binding EditingFlower.Price}" 
                               Minimum="0" 
                               FormatString="0.00" 
                               Padding="10" CornerRadius="5"/>

                <TextBlock Text="Залишок на складі:" FontWeight="SemiBold" Foreground="Gray"/>
                <NumericUpDown Value="{Binding EditingFlower.StockQuantity}" 
                               Minimum="0" 
                               Increment="1" 
                               Padding="10" CornerRadius="5"/>

                <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                    <Button Grid.Column="0" Content="Зберегти" Command="{Binding SaveFlowerCommand}" 
                            Classes="Primary" Background="{DynamicResource BrandGreenBrush}" />
                    
                    <Button Grid.Column="1" Content="Скасувати" Command="{Binding CancelEditCommand}" 
                            Classes="Secondary" Background="{DynamicResource BrandGrayBrush}"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
