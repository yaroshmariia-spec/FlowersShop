<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FlowersShop.ViewModels"
             xmlns:models="using:FlowersShop.Models"
             x:DataType="vm:OrdersViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FlowersShop.Views.OrdersView">
    
    <Grid RowDefinitions="Auto, *" Margin="20">
        <TextBlock Grid.Row="0" Text="{DynamicResource OrdersManagement}" FontSize="28" FontWeight="Bold" 
                   Foreground="{DynamicResource SystemBaseHighColor}" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" ColumnDefinitions="*, *, *" Margin="-10,0">
            
            <StackPanel Grid.Column="0" Margin="10">
                <Border Background="#FFFFE0" BorderBrush="#FFFF00" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource OrdersNewOrder}" FontWeight="Bold" Foreground="#B8860B" HorizontalAlignment="Center"/>
                </Border>
                <ItemsControl ItemsSource="{Binding NewOrders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="Card" Margin="0,0,0,10" Background="{DynamicResource SystemRegionBrush}">
                                <StackPanel>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="{DynamicResource BrandPinkBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Time}" FontSize="11" Foreground="Gray"/>
                                    </Grid>
                                    <TextBlock Text="{Binding CustomerName}" Margin="0,5"/>
                                    <TextBlock Text="{Binding Price}" FontWeight="Bold"/>
                                    <Button Classes="Primary" Content="{DynamicResource OrdersTakeToWork}" FontSize="12" Padding="5" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10">
                <Border Background="#E6E6FA" BorderBrush="#9370DB" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource OrdersProgress}" FontWeight="Bold" Foreground="#4B0082" HorizontalAlignment="Center"/>
                </Border>
                <ItemsControl ItemsSource="{Binding ProcessingOrders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="Card" Margin="0,0,0,10" Background="{DynamicResource SystemRegionBrush}">
                                <StackPanel>
                                    <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="{DynamicResource BrandPinkBrush}"/>
                                    <TextBlock Text="{Binding CustomerName}" Margin="0,5"/>
                                    <TextBlock Text="{Binding Price}" FontWeight="Bold"/>
                                    <Button Classes="Secondary" Content="{DynamicResource OrdersReadyToShip}" FontSize="12" Padding="5" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="10">
                <Border Background="#F0FFF0" BorderBrush="#32CD32" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <TextBlock Text="{DynamicResource OrdersCompleted}" FontWeight="Bold" Foreground="#006400" HorizontalAlignment="Center"/>
                </Border>
                <ItemsControl ItemsSource="{Binding CompletedOrders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="Card" Margin="0,0,0,10" Background="{DynamicResource SystemRegionBrush}" Opacity="0.7">
                                <StackPanel>
                                    <TextBlock Text="{Binding OrderNumber}" FontWeight="Bold" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CustomerName}" Margin="0,5"/>
                                    <TextBlock Text="{Binding Price}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
